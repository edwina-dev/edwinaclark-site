---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const brands = ['Google', 'Intel', 'Tesla', 'Adidas', 'Oatly', 'Primal Kitchen', 'Whirlpool', 'US Fertility', 'Jona', 'OTO Health', 'Elo Health', 'Oshi Health', 'Rousselot', 'Yummly'];
---

<Layout title="About — Edwina Clark">
  <Nav />

  <!-- Hero -->
  <section class="pt-24 md:pt-32 bg-peach">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 items-end">
        <div class="pt-16 pb-12 md:pt-24 md:pb-20">
          <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">About</p>
          <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05]">
            Clinically trained.<br />
            <em class="text-sage">Marketing-tested.</em>
          </h1>
        </div>
        <div class="relative">
          <div class="aspect-[3/4] md:aspect-[4/5] overflow-hidden rounded-t-2xl">
            <img src="/images/headshot-kitchen.jpeg" alt="Edwina Clark" class="w-full h-full object-cover object-top" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-5 gap-16">
        <div class="md:col-span-3 space-y-6 text-lg text-charcoal-light leading-relaxed">
          <p>
            I'm a fractional CMO, registered dietitian, health writer, and media expert who sits at the intersection of nutrition science and marketing. It's a rare combination — and it's exactly what health and wellness brands need.
          </p>
          <p>
            On the marketing side, I've led growth for digital health companies including <strong class="text-charcoal">Elo Health</strong> (where I scaled organic traffic from 0 to 160K monthly sessions and built a 50K-subscriber newsletter), <strong class="text-charcoal">Jona</strong> (microbiome health), and <strong class="text-charcoal">OTO Health</strong> (fertility tech). I've also built SEO content platforms for brands like <strong class="text-charcoal">Rousselot</strong> and led nutrition strategy at <strong class="text-charcoal">Yummly</strong>, reaching 25–30 million weekly users.
          </p>
          <p>
            On the clinical side, my writing has appeared in <strong class="text-charcoal">Shape, SELF, Women's Health, Well+Good, Yahoo Life</strong>, and <strong class="text-charcoal">MyFitnessPal</strong>. I've been quoted as an expert source in over 120 articles across outlets including <strong class="text-charcoal">Teen Vogue, Glamour, Condé Nast Traveler</strong>, and <strong class="text-charcoal">Food Network</strong>.
          </p>
          <p>
            Before going fractional, I was a performance nutritionist at <strong class="text-charcoal">EXOS</strong>, working with corporate wellness programs at Google, Intel, Tesla, and Adidas. That experience taught me how to communicate complex science to non-expert audiences — a skill I bring to every brand I work with.
          </p>
        </div>
        <div class="md:col-span-2">
          <!-- Credentials Cards -->
          <div class="space-y-4">
            <div class="bg-sage-lighter rounded-xl p-6">
              <p class="text-xs uppercase tracking-[0.2em] text-sage mb-2 font-medium">Education</p>
              <p class="text-charcoal font-medium">MS & BS Nutrition</p>
              <p class="text-charcoal-light text-sm mt-1">Boston University (summa cum laude)</p>
            </div>
            <div class="bg-blush rounded-xl p-6">
              <p class="text-xs uppercase tracking-[0.2em] text-sage mb-2 font-medium">Certifications</p>
              <p class="text-charcoal font-medium">RD, CSSD</p>
              <p class="text-charcoal-light text-sm mt-1">Registered Dietitian, Certified Specialist in Sports Dietetics, Accredited Practicing Dietitian (Australia)</p>
            </div>
            <div class="bg-peach rounded-xl p-6">
              <p class="text-xs uppercase tracking-[0.2em] text-sage mb-2 font-medium">Specialties</p>
              <p class="text-charcoal-light text-sm leading-relaxed">Marketing strategy, content & SEO, brand positioning, nutrition, gut health, sports nutrition, fertility, supplements</p>
            </div>
            <div class="bg-sage-lighter rounded-xl p-6">
              <p class="text-xs uppercase tracking-[0.2em] text-sage mb-2 font-medium">Based in</p>
              <p class="text-charcoal font-medium">Alexandria, Virginia</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="py-24 md:py-32 bg-sage-lighter">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">Experience</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-12">Brands I've worked with</h2>
      <div class="flex flex-wrap gap-3">
        {brands.map(brand => (
          <span class="bg-white text-charcoal px-6 py-3 rounded-full text-sm font-medium">
            {brand}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-sage py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
        Let's work<br /><em>together.</em>
      </h2>
      <a href="/contact" class="inline-block bg-white text-sage px-10 py-4 text-sm tracking-wider uppercase rounded-full hover:bg-sage-lighter transition-colors font-medium">
        Get in Touch
      </a>
    </div>
  </section>

  <Footer />
</Layout>
