---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About — Edwina Clark">
  <Nav />

  <section class="pt-32 pb-20 md:pt-44 md:pb-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <!-- Photo -->
        <div>
          <div class="aspect-[3/4] bg-warm-gray rounded-sm overflow-hidden sticky top-28">
            <img src="/images/headshot-kitchen.jpeg" alt="Edwina Clark in the kitchen" class="w-full h-full object-cover" />
          </div>
        </div>

        <!-- Bio -->
        <div>
          <p class="text-sm uppercase tracking-widest text-sage mb-2">About</p>
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-8">Edwina Clark</h1>

          <div class="prose prose-lg text-charcoal-light space-y-5 leading-relaxed">
            <p>
              I'm a fractional CMO, registered dietitian, health writer, and media expert who sits at the intersection of nutrition science and marketing. It's a rare combination — and it's exactly what health and wellness brands need.
            </p>
            <p>
              On the marketing side, I've led growth for digital health companies including <strong class="text-charcoal">Elo Health</strong> (where I scaled organic traffic from 0 to 160K monthly sessions and built a 50K-subscriber newsletter), <strong class="text-charcoal">Jona</strong> (microbiome health), and <strong class="text-charcoal">OTO Health</strong> (fertility tech). I've also built SEO content platforms for brands like <strong class="text-charcoal">Rousselot</strong> and led nutrition strategy at <strong class="text-charcoal">Yummly</strong>, reaching 25–30 million weekly users.
            </p>
            <p>
              On the clinical side, my writing has appeared in <strong class="text-charcoal">Shape, SELF, Women's Health, Well+Good, Yahoo Life</strong>, and <strong class="text-charcoal">MyFitnessPal</strong>. I've been quoted as an expert source in over 120 articles across outlets including <strong class="text-charcoal">Teen Vogue, Glamour, Condé Nast Traveler</strong>, and <strong class="text-charcoal">Food Network</strong>.
            </p>
            <p>
              Before going fractional, I was a performance nutritionist at <strong class="text-charcoal">EXOS</strong>, working with corporate wellness programs at Google, Intel, Tesla, and Adidas. That experience taught me how to communicate complex science to non-expert audiences — a skill I bring to every brand I work with.
            </p>
            <p>
              I hold a Master of Science and Bachelor of Science in Nutrition from Boston University (summa cum laude), and I'm a Certified Specialist in Sports Dietetics (CSSD) and Accredited Practicing Dietitian in Australia.
            </p>
            <p>
              Based in Alexandria, Virginia.
            </p>
          </div>

          <!-- Credentials -->
          <div class="mt-12 pt-8 border-t border-warm-gray-dark">
            <h2 class="text-sm uppercase tracking-widest text-sage mb-6 font-medium">Credentials</h2>
            <div class="grid grid-cols-2 gap-6">
              <div>
                <p class="text-sm font-medium text-charcoal">Education</p>
                <p class="text-sm text-charcoal-light mt-1">MS & BS Nutrition, Boston University (summa cum laude)</p>
              </div>
              <div>
                <p class="text-sm font-medium text-charcoal">Certifications</p>
                <p class="text-sm text-charcoal-light mt-1">RD, CSSD, Accredited Practicing Dietitian (Australia)</p>
              </div>
              <div>
                <p class="text-sm font-medium text-charcoal">Specialties</p>
                <p class="text-sm text-charcoal-light mt-1">Marketing strategy, content & SEO, brand positioning, nutrition, gut health, sports nutrition</p>
              </div>
              <div>
                <p class="text-sm font-medium text-charcoal">Based in</p>
                <p class="text-sm text-charcoal-light mt-1">Alexandria, Virginia</p>
              </div>
            </div>
          </div>

          <!-- Notable Brands -->
          <div class="mt-12 pt-8 border-t border-warm-gray-dark">
            <h2 class="text-sm uppercase tracking-widest text-sage mb-4 font-medium">Brands I've Worked With</h2>
            <p class="text-sm text-charcoal-light leading-relaxed">
              Google, Intel, Tesla, Adidas, Oatly, Primal Kitchen, Whirlpool, US Fertility, Jona, OTO Health, Elo Health, Oshi Health, Rousselot, Yummly
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
