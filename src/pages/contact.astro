---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — Edwina Clark">
  <Nav />

  <section class="pt-32 pb-20 md:pt-44 md:pb-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">
        <!-- Info -->
        <div>
          <p class="text-sm uppercase tracking-widest text-coral mb-2">Contact</p>
          <h1 class="font-display text-4xl md:text-5xl font-bold mb-6">Let's connect.</h1>
          <p class="text-lg text-charcoal-light leading-relaxed mb-10">
            Whether you need a health writer, an expert source for your next story, or a speaker for your event — I'd love to hear from you.
          </p>

          <div class="space-y-8">
            <div>
              <h2 class="text-sm uppercase tracking-widest font-medium text-charcoal mb-2">For media inquiries</h2>
              <p class="text-charcoal-light text-sm leading-relaxed">
                I'm available for expert commentary on tight deadlines. Please include your outlet, topic, and timeline.
              </p>
            </div>
            <div>
              <h2 class="text-sm uppercase tracking-widest font-medium text-charcoal mb-2">For writing projects</h2>
              <p class="text-charcoal-light text-sm leading-relaxed">
                Share a brief overview of your project, target audience, and timeline. I'll get back to you within 1–2 business days.
              </p>
            </div>
            <div>
              <h2 class="text-sm uppercase tracking-widest font-medium text-charcoal mb-2">For speaking</h2>
              <p class="text-charcoal-light text-sm leading-relaxed">
                Include your event details, audience, preferred topic, and date. I speak at conferences, corporate events, and trade shows.
              </p>
            </div>
          </div>

          <div class="mt-10 pt-8 border-t border-warm-gray-dark">
            <p class="text-sm text-charcoal-light">
              <strong class="text-charcoal">Email:</strong>
              <a href="mailto:hello@edwinaclark.com" class="text-coral hover:text-coral-dark transition-colors">hello@edwinaclark.com</a>
            </p>
            <p class="text-sm text-charcoal-light mt-2">
              <strong class="text-charcoal">LinkedIn:</strong>
              <a href="https://www.linkedin.com/in/edwinaclark/" target="_blank" rel="noopener" class="text-coral hover:text-coral-dark transition-colors">linkedin.com/in/edwinaclark</a>
            </p>
          </div>
        </div>

        <!-- Form -->
        <div class="bg-warm-gray p-8 md:p-10 rounded-sm">
          <form name="contact" method="POST" data-netlify="true" class="space-y-6">
            <input type="hidden" name="form-name" value="contact" />
            <div>
              <label for="name" class="block text-sm font-medium text-charcoal mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-white border border-warm-gray-dark text-charcoal text-sm focus:outline-none focus:border-coral transition-colors"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-charcoal mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-white border border-warm-gray-dark text-charcoal text-sm focus:outline-none focus:border-coral transition-colors"
              />
            </div>
            <div>
              <label for="type" class="block text-sm font-medium text-charcoal mb-2">I'm reaching out about</label>
              <select
                id="type"
                name="type"
                class="w-full px-4 py-3 bg-white border border-warm-gray-dark text-charcoal text-sm focus:outline-none focus:border-coral transition-colors"
              >
                <option value="">Select one...</option>
                <option value="writing">Writing project</option>
                <option value="media">Media / expert commentary</option>
                <option value="speaking">Speaking engagement</option>
                <option value="other">Something else</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-charcoal mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 bg-white border border-warm-gray-dark text-charcoal text-sm focus:outline-none focus:border-coral transition-colors resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-coral text-white px-6 py-4 text-sm font-medium uppercase tracking-wide hover:bg-coral-dark transition-colors"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
