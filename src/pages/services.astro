---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const cmoServices = [
  {
    title: 'Brand Positioning & Strategy',
    description: 'Define your brand voice, messaging framework, and competitive positioning. Especially effective for health/wellness brands that need to balance clinical credibility with consumer appeal.',
  },
  {
    title: 'Content & SEO Strategy',
    description: 'Build organic traffic engines with evidence-based content programs. I\'ve taken brands from 0 to 160K monthly organic sessions through strategic, science-backed SEO content.',
  },
  {
    title: 'Go-to-Market & Launch',
    description: 'Product positioning, launch playbooks, B2B and B2C communications, and lead generation assets for digital health products entering new markets.',
  },
  {
    title: 'Team Building & Leadership',
    description: 'Hire, mentor, and manage marketing teams. Scale from founder-led marketing to a structured function with clear KPIs and workflows.',
  },
];

const writingServices = [
  {
    title: 'Bylined Articles',
    description: 'Expert health and nutrition articles for consumer publications, brand blogs, and digital platforms. Published in Shape, SELF, Well+Good, Yahoo Life, and more.',
  },
  {
    title: 'SEO & Educational Content',
    description: 'Evidence-based, search-optimized health content that drives organic traffic while maintaining clinical accuracy. 50+ pages built for Rousselot\'s consumer collagen platform.',
  },
  {
    title: 'Media & Spokesperson',
    description: 'Expert source for journalists on deadline. 120+ media features across SELF, Women\'s Health, Teen Vogue, Glamour, Food Network, and Condé Nast Traveler.',
  },
  {
    title: 'Speaking & Events',
    description: 'Conference talks, panels, and trade show representation at the intersection of nutrition science, digital health, and marketing. Past stages include Girl Geek X and FNCE.',
  },
];

const caseStudies = [
  {
    client: 'Elo Health',
    role: 'Director of Marketing',
    results: [
      'Scaled organic traffic from 0 to 160K monthly sessions',
      'Built 50K-subscriber newsletter from scratch',
      'Hired and managed a team of 5',
      'Led content, SEO, email, and brand strategy',
    ],
  },
  {
    client: 'Jona',
    role: 'Interim Head of Marketing',
    results: [
      'Led marketing for microbiome health startup',
      'Developed brand positioning and growth strategy',
      'Built content pipeline and marketing operations',
    ],
  },
  {
    client: 'OTO Health',
    role: 'Fractional CMO',
    results: [
      'Positioned fertility wearable + app for market entry',
      'Created brand playbook and messaging framework',
      'Developed B2B and B2C communications strategy',
    ],
  },
  {
    client: 'Rousselot',
    role: 'Content Strategy',
    results: [
      'Built consumer-facing collagen education platform',
      '50+ SEO-optimized pages of clinical-grade content',
      'Bridged B2B ingredient brand to consumer audience',
    ],
  },
];
---

<Layout title="Services — Edwina Clark">
  <Nav />

  <section class="pt-32 pb-12 md:pt-44 md:pb-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-sm uppercase tracking-widest text-sage mb-2">Services</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">How I help health brands grow</h1>
      <p class="text-lg text-charcoal-light max-w-2xl leading-relaxed">
        I combine 10+ years of clinical nutrition expertise with hands-on marketing leadership to help digital health, nutrition, and wellness companies build trust and scale.
      </p>
    </div>
  </section>

  <!-- Fractional CMO -->
  <section class="py-20 bg-sage-lighter">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <p class="text-sm uppercase tracking-widest text-sage mb-2">Marketing Leadership</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold">Fractional CMO</h2>
        <p class="text-charcoal-light mt-4 max-w-2xl leading-relaxed">
          Embedded marketing leadership for health and wellness startups — without the full-time executive hire. I work as an extension of your team, typically 2–4 days per week.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {cmoServices.map(service => (
          <div class="bg-white p-8 rounded-sm">
            <h3 class="font-display text-xl font-semibold mb-3">{service.title}</h3>
            <p class="text-charcoal-light text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Writing & Media -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <p class="text-sm uppercase tracking-widest text-sage mb-2">Content & Communications</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold">Writing, Media & Speaking</h2>
        <p class="text-charcoal-light mt-4 max-w-2xl leading-relaxed">
          Health and nutrition content that builds authority — whether you need a writer, an expert source, or a speaker for your next event.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {writingServices.map(service => (
          <div class="bg-sage-lighter p-8 rounded-sm">
            <h3 class="font-display text-xl font-semibold mb-3">{service.title}</h3>
            <p class="text-charcoal-light text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="py-20 bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <p class="text-sm uppercase tracking-widest text-sage-light mb-2">Selected Work</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold">Client results</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {caseStudies.map(study => (
          <div class="bg-white/5 p-8 rounded-sm">
            <div class="flex items-baseline justify-between mb-4">
              <h3 class="font-display text-xl font-semibold text-white">{study.client}</h3>
              <span class="text-xs uppercase tracking-wide text-sage-light">{study.role}</span>
            </div>
            <ul class="space-y-2">
              {study.results.map(result => (
                <li class="flex items-start gap-3 text-white/70 text-sm">
                  <span class="text-sage-light mt-0.5">&#10003;</span>
                  {result}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ideal Client -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm uppercase tracking-widest text-sage mb-2">Best Fit</p>
          <h2 class="font-display text-3xl font-semibold mb-6">Who I work with</h2>
          <ul class="space-y-4 text-charcoal-light">
            <li class="flex items-start gap-3">
              <span class="text-sage mt-0.5">&#10003;</span>
              <span>Digital health and wellness <strong class="text-charcoal">startups (Series A–C)</strong> that need marketing leadership without a full-time CMO hire</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-sage mt-0.5">&#10003;</span>
              <span>Health, nutrition, and supplement brands that need <strong class="text-charcoal">clinically credible content</strong> to build trust</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-sage mt-0.5">&#10003;</span>
              <span>Publications and media outlets looking for a <strong class="text-charcoal">reliable nutrition expert</strong> who can write or comment on deadline</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-sage mt-0.5">&#10003;</span>
              <span>Companies seeking a <strong class="text-charcoal">speaker</strong> at the intersection of nutrition science, digital health, and marketing</span>
            </li>
          </ul>
        </div>
        <div class="aspect-[4/3] rounded-sm overflow-hidden">
          <img src="/images/headshot-cooking.jpg" alt="Edwina Clark" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-blush-light">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-semibold mb-4">Ready to work together?</h2>
      <p class="text-charcoal-light leading-relaxed mb-8 max-w-xl mx-auto">
        Tell me about your brand, your goals, and the challenge you're trying to solve. I'll get back to you within 1–2 business days.
      </p>
      <a href="/contact" class="inline-block bg-sage text-white px-8 py-4 text-sm font-medium uppercase tracking-wide hover:bg-sage-dark transition-colors">
        Start a Conversation
      </a>
    </div>
  </section>

  <Footer />
</Layout>
