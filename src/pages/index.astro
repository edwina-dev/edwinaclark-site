---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const mediaLogos = [
  { name: 'SELF', src: '/images/logos/self.png' },
  { name: 'Women\'s Health', src: '/images/logos/womens-health.png' },
  { name: 'Shape', src: '/images/logos/shape.png' },
  { name: 'Glamour', src: '/images/logos/glamour.png' },
  { name: 'Food Network', src: '/images/logos/food-network.png' },
  { name: 'MyFitnessPal', src: '/images/logos/myfitnesspal.png' },
  { name: 'HuffPost', src: '/images/logos/huffpost.png' },
  { name: 'Prevention', src: '/images/logos/prevention.png' },
  { name: 'Everyday Health', src: '/images/logos/everyday-health.png' },
];

const marqueeItems = ['Brand Strategy', 'SEO & Content', 'Nutrition Writing', 'Media Expert', 'Recipe Development', 'Fractional CMO', 'TV Segments', 'Digital Health', 'Brand Strategy', 'SEO & Content', 'Nutrition Writing', 'Media Expert', 'Recipe Development', 'Fractional CMO', 'TV Segments', 'Digital Health'];

const results = [
  { metric: '0 → 160K', label: 'Monthly organic sessions at Elo Health' },
  { metric: '50K', label: 'Newsletter subscribers built from scratch' },
  { metric: '130+', label: 'Media features across national outlets' },
  { metric: '50+', label: 'SEO pages for Rousselot collagen platform' },
];

const clients = [
  { name: 'Elo Health', desc: 'Personalized nutrition' },
  { name: 'Jona', desc: 'Microbiome health' },
  { name: 'OTO Health', desc: 'Fertility wearable' },
  { name: 'Oshi Health', desc: 'GI digital health' },
  { name: 'Rousselot', desc: 'Consumer collagen' },
  { name: 'Yummly', desc: '25–30M weekly users' },
];

const expertiseAreas = [
  'Nutrition & dietetics', 'Gut health & microbiome', 'Sports nutrition',
  'Fertility & prenatal', 'Supplements & nutraceuticals', 'Digital health marketing',
  'Brand positioning', 'Content & SEO strategy', 'Health communications',
  'Recipe development & food photography', 'TV segments & broadcast', 'Consumer wellness',
];
---

<Layout title="Edwina Clark — Fractional CMO, Health Writer, & Media Expert">
  <Nav />

  <!-- Hero — bold, overlapping layout -->
  <section class="pt-24 md:pt-32 bg-sage-lighter">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 items-end">
        <div class="pt-16 pb-12 md:pt-24 md:pb-20">
          <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] mb-6">
            Where nutrition science
            <em class="text-sage">meets marketing.</em>
          </h1>
          <p class="text-lg md:text-xl text-charcoal-light leading-relaxed mb-8 max-w-md">
            Fractional CMO, health writer, and media expert helping digital health brands grow with clinical credibility.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/services" class="bg-sage text-white px-8 py-3.5 text-sm tracking-wider uppercase rounded-full hover:bg-sage-dark transition-colors">
              How I Help
            </a>
            <a href="/writing-media" class="border-2 border-charcoal text-charcoal px-8 py-3.5 text-sm tracking-wider uppercase rounded-full hover:bg-charcoal hover:text-white transition-colors">
              See My Work
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[3/4] md:aspect-[4/5] overflow-hidden rounded-t-2xl">
            <img src="/images/headshot-hero.jpeg" alt="Edwina Clark" class="w-full h-full object-cover object-top" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Scrolling Marquee -->
  <section class="bg-sage py-5 overflow-hidden">
    <div class="flex whitespace-nowrap marquee-track">
      {marqueeItems.map(item => (
        <span class="text-white/90 text-sm md:text-base tracking-widest uppercase mx-8 flex items-center gap-8">
          {item} <span class="text-sage-light text-lg">&middot;</span>
        </span>
      ))}
    </div>
  </section>

  <!-- Media Logos -->
  <section class="py-14 border-b border-sage-lighter">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-center text-xs uppercase tracking-[0.2em] text-charcoal-light/60 mb-10">Featured in 130+ publications including</p>
      <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6">
        {mediaLogos.map(logo => (
          <img src={logo.src} alt={logo.name} class="h-8 md:h-10 w-auto opacity-50 hover:opacity-80 transition-opacity" />
        ))}
      </div>
    </div>
  </section>

  <!-- Two Pillars — overlapping card style -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">What I Do</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-16 max-w-3xl">
        Marketing leadership<br />
        <em class="text-sage">+ nutrition expertise.</em>
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-sage-lighter rounded-2xl p-10 md:p-12">
          <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4 font-medium">Marketing Leader</p>
          <h3 class="font-display text-3xl font-bold mb-4">Fractional CMO for health brands</h3>
          <p class="text-charcoal-light leading-relaxed mb-8">
            I embed with digital health and wellness startups as their marketing leader — building brand positioning, content engines, and growth strategies that are grounded in real science.
          </p>
          <a href="/services" class="inline-block bg-sage text-white px-7 py-3 text-sm tracking-wider uppercase rounded-full hover:bg-sage-dark transition-colors">
            View Services
          </a>
        </div>
        <div class="bg-blush rounded-2xl p-10 md:p-12">
          <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4 font-medium">Nutrition Expert</p>
          <h3 class="font-display text-3xl font-bold mb-4">Writer & media spokesperson</h3>
          <p class="text-charcoal-light leading-relaxed mb-8">
            I translate complex nutrition science into clear, compelling stories — as a bylined writer for top publications and a trusted expert source for national media.
          </p>
          <a href="/writing-media" class="inline-block bg-sage text-white px-7 py-3 text-sm tracking-wider uppercase rounded-full hover:bg-sage-dark transition-colors">
            View Work
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Results — bold numbers on dark background -->
  <section class="bg-charcoal text-white py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-sage-light mb-4">Results</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-6">
            We don't do it for the vanity metrics; we do it for the <em class="text-sage-light">results.</em>
          </h2>
          <p class="text-white/60 leading-relaxed">
            Every engagement is measured by what matters: traffic, trust, and revenue growth for health brands that need clinical credibility to scale.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-8">
          {results.map(r => (
            <div>
              <p class="font-display text-3xl md:text-4xl font-bold text-sage-light">{r.metric}</p>
              <p class="text-white/50 text-sm mt-2 leading-relaxed">{r.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Clients — card grid -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">Clients</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-6">
            Trusted by health & wellness brands
          </h2>
          <p class="text-charcoal-light leading-relaxed">
            From venture-backed startups to established consumer brands, I help companies find their voice, build authority, and grow sustainably.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {clients.map(client => (
            <div class="bg-sage-lighter rounded-xl p-6">
              <p class="font-display text-lg font-semibold">{client.name}</p>
              <p class="text-charcoal-light text-sm mt-1">{client.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise Marquee + Tags -->
  <section class="py-24 md:py-32 bg-peach">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">Expertise</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight">
            Deep knowledge across health, nutrition, <em class="text-sage">& marketing</em>
          </h2>
        </div>
        <div class="flex flex-wrap gap-3">
          {expertiseAreas.map(area => (
            <span class="bg-white/80 text-charcoal px-5 py-2.5 rounded-full text-sm">
              {area}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Broadcast Preview -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">As Seen On TV</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-6">
            Broadcast nutrition<br /><em class="text-sage">expert.</em>
          </h2>
          <p class="text-charcoal-light leading-relaxed mb-4">
            Regular nutrition expert on WTTG Fox 5 DC and trusted source for 130+ media features across SELF, Women's Health, Shape, Teen Vogue, and more.
          </p>
          <p class="text-charcoal-light leading-relaxed mb-8">
            Also available for recipe development, food photography, and recipe videos — combining culinary creativity with clinical nutrition expertise.
          </p>
          <a href="/writing-media" class="inline-block bg-sage text-white px-8 py-3.5 text-sm tracking-wider uppercase rounded-full hover:bg-sage-dark transition-colors">
            Watch Clips & See Work
          </a>
        </div>
        <div class="aspect-video bg-charcoal rounded-2xl overflow-hidden">
          <video class="w-full h-full object-cover" controls preload="metadata">
            <source src="/videos/wttg-snack-hacks.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA — bold background -->
  <section class="bg-sage py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Ready to grow your<br /><em>health brand?</em>
      </h2>
      <p class="text-white/70 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        Whether you need a fractional CMO, a health writer, or an expert source — let's talk about how I can help.
      </p>
      <a href="/contact" class="inline-block bg-white text-sage px-10 py-4 text-sm tracking-wider uppercase rounded-full hover:bg-sage-lighter transition-colors font-medium">
        Start a Conversation
      </a>
    </div>
  </section>

  <Footer />
</Layout>
