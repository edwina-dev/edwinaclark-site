---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const articles = [
  { title: 'What a Dietitian Actually Eats in a Day', outlet: 'Shape', category: 'Nutrition', url: '#' },
  { title: 'The Science Behind Gut Health Claims', outlet: 'Well+Good', category: 'Gut Health', url: '#' },
  { title: 'Sports Nutrition Myths That Won\'t Die', outlet: 'SELF', category: 'Sports Nutrition', url: '#' },
  { title: 'Prenatal Nutrition: What the Research Really Says', outlet: 'Yahoo Life', category: 'Fertility', url: '#' },
  { title: 'Do You Actually Need a Collagen Supplement?', outlet: 'Women\'s Health', category: 'Supplements', url: '#' },
  { title: 'How Ultra-Processed Foods Affect Your Microbiome', outlet: 'Well+Good', category: 'Gut Health', url: '#' },
  { title: 'Fueling for Endurance: A Dietitian\'s Guide', outlet: 'MyFitnessPal', category: 'Sports Nutrition', url: '#' },
  { title: 'The Anti-Diet Approach to Healthy Eating', outlet: 'Shape', category: 'Nutrition', url: '#' },
  { title: 'Supplements That Are Actually Worth Taking', outlet: 'SELF', category: 'Supplements', url: '#' },
];

const mediaFeatures = [
  { outlet: 'SELF', topic: 'Hydration myths debunked' },
  { outlet: 'Women\'s Health', topic: 'Best foods for gut health' },
  { outlet: 'Teen Vogue', topic: 'Healthy eating on a college budget' },
  { outlet: 'Glamour', topic: 'Supplement industry red flags' },
  { outlet: 'Shape', topic: 'Recovery nutrition for athletes' },
  { outlet: 'Condé Nast Traveler', topic: 'Eating well while traveling' },
  { outlet: 'Food Network', topic: 'Pantry staples every kitchen needs' },
  { outlet: 'Yahoo Life', topic: 'Intermittent fasting pros and cons' },
  { outlet: 'Well+Good', topic: 'The truth about detox diets' },
  { outlet: 'MyFitnessPal', topic: 'Macro counting: when it helps and when it hurts' },
  { outlet: 'SELF', topic: 'Anti-inflammatory eating patterns' },
  { outlet: 'Women\'s Health', topic: 'Prenatal vitamin guide' },
];

const broadcastClips = [
  { title: 'Healthy Snack Hacks', show: 'WTTG Fox 5 DC', date: 'January 2026', video: '/videos/wttg-snack-hacks.mp4' },
  { title: 'Heart-Healthy Foods', show: 'WTTG Fox 5 DC', date: 'February 2026', video: '/videos/wttg-heart-healthy.mp4' },
  { title: 'Gut Health Essentials', show: 'WTTG Fox 5 DC', date: 'March 2026', video: '/videos/wttg-gut-health.mp4' },
];

const recipeVideos = [
  { title: 'Sheet Pan Salmon & Veggies', video: '/videos/recipe-salmon.mp4' },
  { title: 'Avocado Mousse', video: '/videos/recipe-avocado-mousse.mp4' },
  { title: 'Chicken & Veggie Frittata', video: '/videos/recipe-frittata.mp4' },
];

const contentCategories = ['Recipes', 'TV Segments', 'Articles', 'Videos', 'Recipe Development', 'Food Photography', 'Recipes', 'TV Segments', 'Articles', 'Videos', 'Recipe Development', 'Food Photography'];

const speakingTopics = [
  'Evidence-based nutrition in the age of misinformation',
  'Building trust through science-backed health content',
  'Nutrition marketing: bridging clinical credibility and consumer appeal',
  'Sports nutrition for the everyday athlete',
  'The intersection of digital health and nutrition science',
];

const speakingVenues = [
  { name: 'Girl Geek X', type: 'Conference' },
  { name: 'FNCE', type: 'Conference' },
  { name: 'Trade Shows', type: 'Events' },
  { name: 'Corporate Events', type: 'Events' },
];
---

<Layout title="Writing & Media — Edwina Clark">
  <Nav />

  <!-- Hero -->
  <section class="pt-24 md:pt-32 bg-blush">
    <div class="max-w-7xl mx-auto px-6 pt-16 pb-20 md:pt-24 md:pb-28">
      <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">Writing, Media & Recipes</p>
      <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] mb-6 max-w-4xl">
        Expert voice in health <em class="text-sage">& nutrition.</em>
      </h1>
      <p class="text-xl text-charcoal-light max-w-2xl leading-relaxed">
        Bylined articles, broadcast TV segments, recipe development, and expert commentary — grounded in clinical expertise and a passion for making nutrition accessible.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 bg-white border-b border-sage-lighter">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-sage">130+</p>
          <p class="text-sm text-charcoal-light mt-1">Media Features</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-sage">1B+</p>
          <p class="text-sm text-charcoal-light mt-1">Reach in Top-Tier Publications</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-sage">50+</p>
          <p class="text-sm text-charcoal-light mt-1">Publications</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-sage">6+</p>
          <p class="text-sm text-charcoal-light mt-1">Topic Areas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Category Marquee -->
  <section class="bg-sage py-4 overflow-hidden">
    <div class="flex whitespace-nowrap marquee-track">
      {contentCategories.map(cat => (
        <span class="font-display text-2xl md:text-3xl italic text-white/80 mx-6 flex items-center gap-6">
          {cat} <span class="text-sage-light">&middot;</span>
        </span>
      ))}
    </div>
  </section>

  <!-- Broadcast Clips -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">Broadcast</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-6">TV Segments</h2>
      <p class="text-charcoal-light text-lg leading-relaxed mb-12 max-w-2xl">
        Regular nutrition expert on WTTG Fox 5 DC — delivering practical, science-backed nutrition advice for live morning television.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        {broadcastClips.map(clip => (
          <div class="group">
            <div class="aspect-video bg-charcoal rounded-2xl overflow-hidden mb-4">
              <video
                class="w-full h-full object-cover"
                controls
                preload="metadata"
                poster=""
              >
                <source src={clip.video} type="video/mp4" />
              </video>
            </div>
            <p class="text-xs uppercase tracking-[0.2em] text-sage">{clip.show} &middot; {clip.date}</p>
            <h3 class="font-display text-xl font-semibold mt-2">{clip.title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recipe Development -->
  <section class="py-24 md:py-32 bg-peach">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-start mb-16">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">Custom Content</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight">
            Recipe development <em class="text-sage">& food content</em>
          </h2>
        </div>
        <div>
          <p class="text-charcoal-light leading-relaxed text-lg">
            Original recipe development, food photography, and recipe videos for brands — combining culinary creativity with nutrition expertise. Every recipe is dietitian-developed and camera-ready.
          </p>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {recipeVideos.map(recipe => (
          <div class="group">
            <div class="aspect-[4/5] bg-charcoal rounded-2xl overflow-hidden mb-4">
              <video
                class="w-full h-full object-cover"
                controls
                preload="metadata"
                playsinline
              >
                <source src={recipe.video} type="video/mp4" />
              </video>
            </div>
            <h3 class="font-display text-xl font-semibold">{recipe.title}</h3>
            <p class="text-charcoal-light text-sm mt-1">Recipe development & video</p>
          </div>
        ))}
      </div>
      <div class="mt-12 flex flex-wrap gap-3">
        <span class="bg-white/70 text-charcoal px-5 py-2.5 rounded-full text-sm">Recipe development</span>
        <span class="bg-white/70 text-charcoal px-5 py-2.5 rounded-full text-sm">Food photography</span>
        <span class="bg-white/70 text-charcoal px-5 py-2.5 rounded-full text-sm">Recipe videos</span>
        <span class="bg-white/70 text-charcoal px-5 py-2.5 rounded-full text-sm">Nutrition analysis</span>
        <span class="bg-white/70 text-charcoal px-5 py-2.5 rounded-full text-sm">Brand partnerships</span>
      </div>
    </div>
  </section>

  <!-- Writing Portfolio -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">Bylined Work</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-16">Writing</h2>
      <div class="grid md:grid-cols-3 gap-5">
        {articles.map((article, i) => (
          <a href={article.url} class:list={[
            'group block rounded-2xl p-7 transition-colors',
            i % 3 === 0 ? 'bg-sage-lighter hover:bg-sage-light/40' : i % 3 === 1 ? 'bg-blush-light hover:bg-blush/60' : 'bg-peach/60 hover:bg-peach'
          ]}>
            <span class="text-xs uppercase tracking-[0.2em] text-sage">{article.outlet}</span>
            <h3 class="font-display text-xl font-semibold mt-3 mb-3 group-hover:text-sage transition-colors">{article.title}</h3>
            <span class="text-xs uppercase tracking-wider text-charcoal-light/60 bg-white/60 px-3 py-1 rounded-full">{article.category}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Media Features -->
  <section class="py-24 md:py-32 bg-sage-lighter">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div class="md:sticky md:top-28">
          <p class="text-xs uppercase tracking-[0.2em] text-sage mb-4">Expert Source</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-6">
            Media features
          </h2>
          <p class="text-charcoal-light leading-relaxed">
            Trusted by journalists across national publications for clear, evidence-based nutrition commentary. Available on tight deadlines for print, digital, broadcast, and podcast.
          </p>
        </div>
        <div class="divide-y divide-sage-light/50">
          {mediaFeatures.map(feature => (
            <div class="py-4 flex items-baseline gap-4">
              <span class="font-display text-lg italic text-charcoal flex-shrink-0 w-36">{feature.outlet}</span>
              <p class="text-charcoal-light text-sm">{feature.topic}</p>
            </div>
          ))}
          <p class="pt-6 text-sm text-charcoal-light italic">Full media list available on request.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Speaking -->
  <section class="py-24 md:py-32 bg-charcoal text-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-sage-light mb-4">Speaking</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-8">
            Edwina has spoken for groups such as
          </h2>
          <div class="grid grid-cols-2 gap-4">
            {speakingVenues.map(venue => (
              <div class="bg-white/5 rounded-xl p-5">
                <p class="font-medium text-white">{venue.name}</p>
                <p class="text-white/40 text-sm mt-1">{venue.type}</p>
              </div>
            ))}
          </div>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 mb-6">On topics like</p>
          <div class="flex flex-wrap gap-3">
            {speakingTopics.map(topic => (
              <span class="bg-white/10 text-white/80 px-5 py-2.5 rounded-full text-sm">
                {topic}
              </span>
            ))}
          </div>
          <div class="mt-12">
            <a href="/contact" class="inline-block border-2 border-sage-light text-sage-light px-8 py-3.5 text-sm tracking-wider uppercase rounded-full hover:bg-sage-light hover:text-charcoal transition-colors">
              Book Me to Speak
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- For Journalists CTA -->
  <section class="py-24 md:py-32 bg-blush">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-4">For Journalists & Producers</h2>
      <p class="text-charcoal-light leading-relaxed mb-4 text-lg max-w-2xl mx-auto">
        Available for expert commentary, TV segments, and recipe demonstrations on nutrition, gut health, sports nutrition, fertility, supplements, and wellness trends.
      </p>
      <p class="text-charcoal-light leading-relaxed mb-10">
        <strong class="text-charcoal">Credentials:</strong> MS Nutrition (Boston University, summa cum laude), RD, CSSD
      </p>
      <a href="/contact" class="inline-block bg-sage text-white px-10 py-4 text-sm tracking-wider uppercase rounded-full hover:bg-sage-dark transition-colors">
        Request an Interview
      </a>
    </div>
  </section>

  <Footer />
</Layout>
