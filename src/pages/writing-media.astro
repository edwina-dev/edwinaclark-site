---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const articles = [
  {
    title: 'What a Dietitian Actually Eats in a Day',
    outlet: 'Shape',
    category: 'Nutrition',
    url: '#',
  },
  {
    title: 'The Science Behind Gut Health Claims',
    outlet: 'Well+Good',
    category: 'Gut Health',
    url: '#',
  },
  {
    title: 'Sports Nutrition Myths That Won\'t Die',
    outlet: 'SELF',
    category: 'Sports Nutrition',
    url: '#',
  },
  {
    title: 'Prenatal Nutrition: What the Research Really Says',
    outlet: 'Yahoo Life',
    category: 'Fertility',
    url: '#',
  },
  {
    title: 'Do You Actually Need a Collagen Supplement?',
    outlet: 'Women\'s Health',
    category: 'Supplements',
    url: '#',
  },
  {
    title: 'How Ultra-Processed Foods Affect Your Microbiome',
    outlet: 'Well+Good',
    category: 'Gut Health',
    url: '#',
  },
  {
    title: 'Fueling for Endurance: A Dietitian\'s Guide',
    outlet: 'MyFitnessPal',
    category: 'Sports Nutrition',
    url: '#',
  },
  {
    title: 'The Anti-Diet Approach to Healthy Eating',
    outlet: 'Shape',
    category: 'Nutrition',
    url: '#',
  },
  {
    title: 'Supplements That Are Actually Worth Taking',
    outlet: 'SELF',
    category: 'Supplements',
    url: '#',
  },
];

const mediaFeatures = [
  { outlet: 'SELF', topic: 'Hydration myths debunked' },
  { outlet: 'Women\'s Health', topic: 'Best foods for gut health' },
  { outlet: 'Teen Vogue', topic: 'Healthy eating on a college budget' },
  { outlet: 'Glamour', topic: 'Supplement industry red flags' },
  { outlet: 'Shape', topic: 'Recovery nutrition for athletes' },
  { outlet: 'Condé Nast Traveler', topic: 'Eating well while traveling' },
  { outlet: 'Food Network', topic: 'Pantry staples every kitchen needs' },
  { outlet: 'Yahoo Life', topic: 'Intermittent fasting pros and cons' },
  { outlet: 'Well+Good', topic: 'The truth about detox diets' },
  { outlet: 'MyFitnessPal', topic: 'Macro counting: when it helps and when it hurts' },
  { outlet: 'SELF', topic: 'Anti-inflammatory eating patterns' },
  { outlet: 'Women\'s Health', topic: 'Prenatal vitamin guide' },
];

const speakingTopics = [
  'Evidence-based nutrition in the age of misinformation',
  'Building trust through science-backed health content',
  'Nutrition marketing: bridging clinical credibility and consumer appeal',
  'Sports nutrition for the everyday athlete',
  'The intersection of digital health and nutrition science',
];
---

<Layout title="Writing & Media — Edwina Clark">
  <Nav />

  <section class="pt-32 pb-12 md:pt-44 md:pb-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-sm uppercase tracking-widest text-sage mb-2">Writing & Media</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Expert voice in health & nutrition</h1>
      <p class="text-lg text-charcoal-light max-w-2xl leading-relaxed">
        Bylined articles for top publications, expert commentary for national media, and speaking at industry events — all grounded in clinical nutrition expertise and a decade of health communications.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="py-10 bg-sage-lighter">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-3 gap-8 text-center">
        <div>
          <p class="font-display text-3xl md:text-4xl font-bold text-sage">120+</p>
          <p class="text-sm text-charcoal-light mt-1">Media Features</p>
        </div>
        <div>
          <p class="font-display text-3xl md:text-4xl font-bold text-sage">50+</p>
          <p class="text-sm text-charcoal-light mt-1">Publications</p>
        </div>
        <div>
          <p class="font-display text-3xl md:text-4xl font-bold text-sage">6+</p>
          <p class="text-sm text-charcoal-light mt-1">Topic Areas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Writing -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <p class="text-sm uppercase tracking-widest text-sage mb-2">Bylined Work</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold">Writing</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {articles.map(article => (
          <a href={article.url} class="group block p-6 bg-sage-lighter/50 rounded-sm hover:bg-sage-lighter transition-colors">
            <span class="text-xs uppercase tracking-widest text-sage">{article.outlet}</span>
            <h3 class="font-display text-lg font-semibold mt-2 mb-2 group-hover:text-sage transition-colors">{article.title}</h3>
            <span class="text-xs uppercase tracking-wide text-charcoal-light/60">{article.category}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Media Features -->
  <section class="py-20 bg-warm-gray">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <p class="text-sm uppercase tracking-widest text-sage mb-2">Expert Source</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold">Media Features</h2>
        <p class="text-charcoal-light mt-4 max-w-2xl leading-relaxed">
          Trusted by journalists across national publications for clear, evidence-based nutrition commentary. Available on tight deadlines for print, digital, broadcast, and podcast.
        </p>
      </div>
      <div class="divide-y divide-warm-gray-dark">
        {mediaFeatures.map(feature => (
          <div class="py-4 grid grid-cols-12 gap-4 items-center">
            <div class="col-span-4 md:col-span-3">
              <span class="font-display text-lg italic text-charcoal">{feature.outlet}</span>
            </div>
            <div class="col-span-8 md:col-span-9">
              <p class="text-charcoal-light text-sm md:text-base">{feature.topic}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="text-sm text-charcoal-light mt-8 italic">Showing a selection — full media list available on request.</p>
    </div>
  </section>

  <!-- Speaking -->
  <section class="py-20 bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <p class="text-sm uppercase tracking-widest text-sage-light mb-2">Speaking</p>
          <h2 class="font-display text-3xl font-semibold mb-6">Conference & Event Speaker</h2>
          <p class="text-white/70 leading-relaxed mb-6">
            I speak at industry conferences, corporate events, and trade shows on topics at the intersection of nutrition science, digital health, and content strategy. Past stages include Girl Geek X and FNCE.
          </p>
          <a href="/contact" class="inline-block border border-sage-light text-sage-light px-6 py-3 text-sm font-medium uppercase tracking-wide hover:bg-sage-light hover:text-charcoal transition-colors">
            Book Me to Speak
          </a>
        </div>
        <div>
          <p class="text-sm uppercase tracking-widest text-white/40 mb-4">Sample Topics</p>
          <ul class="space-y-4">
            {speakingTopics.map(topic => (
              <li class="flex items-start gap-3 text-white/70">
                <span class="text-sage-light mt-1 text-lg leading-none">&bull;</span>
                {topic}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- For Journalists CTA -->
  <section class="py-20 bg-blush-light">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-semibold mb-4">For Journalists & Producers</h2>
      <p class="text-charcoal-light leading-relaxed mb-4">
        I'm available for expert commentary on nutrition, gut health, sports nutrition, fertility, supplements, and wellness trends. I work on tight deadlines and provide clear, quotable insights backed by current research.
      </p>
      <p class="text-charcoal-light leading-relaxed mb-8">
        <strong class="text-charcoal">Credentials:</strong> MS Nutrition (Boston University, summa cum laude), RD, CSSD
      </p>
      <a href="/contact" class="inline-block bg-sage text-white px-8 py-4 text-sm font-medium uppercase tracking-wide hover:bg-sage-dark transition-colors">
        Request an Interview
      </a>
    </div>
  </section>

  <Footer />
</Layout>
