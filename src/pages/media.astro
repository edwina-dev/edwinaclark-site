---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const mediaFeatures = [
  { outlet: 'SELF', topic: 'Hydration myths debunked', type: 'Expert quote' },
  { outlet: 'Women\'s Health', topic: 'Best foods for gut health', type: 'Expert quote' },
  { outlet: 'Teen Vogue', topic: 'Healthy eating on a college budget', type: 'Expert quote' },
  { outlet: 'Glamour', topic: 'Supplement industry red flags', type: 'Expert quote' },
  { outlet: 'Shape', topic: 'Recovery nutrition for athletes', type: 'Expert quote' },
  { outlet: 'Condé Nast Traveler', topic: 'Eating well while traveling', type: 'Expert quote' },
  { outlet: 'Food Network', topic: 'Pantry staples every kitchen needs', type: 'Expert quote' },
  { outlet: 'Yahoo Life', topic: 'Intermittent fasting pros and cons', type: 'Expert quote' },
  { outlet: 'Well+Good', topic: 'The truth about detox diets', type: 'Expert quote' },
  { outlet: 'MyFitnessPal', topic: 'Macro counting: when it helps and when it hurts', type: 'Expert source' },
  { outlet: 'SELF', topic: 'Anti-inflammatory eating patterns', type: 'Expert quote' },
  { outlet: 'Women\'s Health', topic: 'Prenatal vitamin guide', type: 'Expert source' },
];

const speakingTopics = [
  'Evidence-based nutrition in the age of misinformation',
  'Building trust through science-backed health content',
  'Nutrition marketing: bridging clinical credibility and consumer appeal',
  'Sports nutrition for the everyday athlete',
  'The intersection of digital health and nutrition science',
];
---

<Layout title="Media — Edwina Clark">
  <Nav />

  <section class="pt-32 pb-12 md:pt-44 md:pb-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-sm uppercase tracking-widest text-sage mb-2">Press & Speaking</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Media</h1>
      <p class="text-lg text-charcoal-light max-w-2xl leading-relaxed">
        Featured as a nutrition expert in 120+ articles across major national and international publications. Available for media commentary, podcast interviews, and speaking engagements.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 bg-sage-lighter">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-display text-4xl font-bold text-sage">120+</p>
          <p class="text-sm text-charcoal-light mt-1">Media Features</p>
        </div>
        <div>
          <p class="font-display text-4xl font-bold text-sage">50+</p>
          <p class="text-sm text-charcoal-light mt-1">Publications</p>
        </div>
        <div>
          <p class="font-display text-4xl font-bold text-sage">10+</p>
          <p class="text-sm text-charcoal-light mt-1">Years as Expert Source</p>
        </div>
        <div>
          <p class="font-display text-4xl font-bold text-sage">6+</p>
          <p class="text-sm text-charcoal-light mt-1">Topic Areas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Media Features List -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display text-2xl md:text-3xl font-semibold mb-10">Selected Features</h2>
      <div class="divide-y divide-warm-gray-dark">
        {mediaFeatures.map(feature => (
          <div class="py-5 grid grid-cols-12 gap-4 items-center group">
            <div class="col-span-4 md:col-span-3">
              <span class="font-display text-lg italic text-charcoal">{feature.outlet}</span>
            </div>
            <div class="col-span-6 md:col-span-7">
              <p class="text-charcoal-light text-sm md:text-base">{feature.topic}</p>
            </div>
            <div class="col-span-2 text-right">
              <span class="text-xs uppercase tracking-wide text-charcoal-light/60">{feature.type}</span>
            </div>
          </div>
        ))}
      </div>
      <p class="text-sm text-charcoal-light mt-8 italic">Showing a selection — full media list available on request.</p>
    </div>
  </section>

  <!-- Speaking -->
  <section class="py-20 bg-charcoal text-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <p class="text-sm uppercase tracking-widest text-sage-light mb-2">Speaking</p>
          <h2 class="font-display text-3xl font-semibold mb-6">Conference & Event Speaker</h2>
          <p class="text-white/70 leading-relaxed mb-6">
            I speak at industry conferences, corporate events, and trade shows on topics at the intersection of nutrition science, digital health, and content strategy. Past stages include Girl Geek X and FNCE.
          </p>
          <a href="/contact" class="inline-block border border-sage-light text-sage-light px-6 py-3 text-sm font-medium uppercase tracking-wide hover:bg-sage-light hover:text-charcoal transition-colors">
            Book Me to Speak
          </a>
        </div>
        <div>
          <p class="text-sm uppercase tracking-widest text-white/40 mb-4">Sample Topics</p>
          <ul class="space-y-4">
            {speakingTopics.map(topic => (
              <li class="flex items-start gap-3 text-white/70">
                <span class="text-sage-light mt-1 text-lg leading-none">&bull;</span>
                {topic}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- For Journalists -->
  <section class="py-20 bg-blush-light">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-semibold mb-4">For Journalists & Producers</h2>
      <p class="text-charcoal-light leading-relaxed mb-4">
        I'm available for expert commentary on nutrition, gut health, sports nutrition, fertility nutrition, supplements, and wellness trends. I can work on tight deadlines and provide clear, quotable insights backed by current research.
      </p>
      <p class="text-charcoal-light leading-relaxed mb-8">
        <strong class="text-charcoal">Credentials:</strong> MS Nutrition (Boston University, summa cum laude), Registered Dietitian, Certified Specialist in Sports Dietetics (CSSD)
      </p>
      <a href="/contact" class="inline-block bg-sage text-white px-8 py-4 text-sm font-medium uppercase tracking-wide hover:bg-sage-dark transition-colors">
        Request an Interview
      </a>
    </div>
  </section>

  <Footer />
</Layout>
