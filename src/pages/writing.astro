---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const categories = ['All', 'Nutrition', 'Gut Health', 'Sports Nutrition', 'Fertility', 'Supplements', 'Wellness'];

const articles = [
  {
    title: 'What a Dietitian Actually Eats in a Day',
    outlet: 'Shape',
    category: 'Nutrition',
    description: 'An honest look at intuitive eating from a registered dietitian\'s perspective.',
    url: '#',
  },
  {
    title: 'The Science Behind Gut Health Claims',
    outlet: 'Well+Good',
    category: 'Gut Health',
    description: 'Separating evidence-based gut health strategies from social media hype.',
    url: '#',
  },
  {
    title: 'Sports Nutrition Myths That Won\'t Die',
    outlet: 'SELF',
    category: 'Sports Nutrition',
    description: 'Debunking persistent sports nutrition misconceptions with current research.',
    url: '#',
  },
  {
    title: 'Prenatal Nutrition: What the Research Really Says',
    outlet: 'Yahoo Life',
    category: 'Fertility',
    description: 'Evidence-based prenatal nutrition guidance beyond the standard recommendations.',
    url: '#',
  },
  {
    title: 'Do You Actually Need a Collagen Supplement?',
    outlet: 'Women\'s Health',
    category: 'Supplements',
    description: 'A critical look at the collagen supplement trend through a clinical lens.',
    url: '#',
  },
  {
    title: 'How Ultra-Processed Foods Affect Your Microbiome',
    outlet: 'Well+Good',
    category: 'Gut Health',
    description: 'Connecting the dots between food processing and gut health outcomes.',
    url: '#',
  },
  {
    title: 'Fueling for Endurance: A Dietitian\'s Guide',
    outlet: 'MyFitnessPal',
    category: 'Sports Nutrition',
    description: 'Practical sports nutrition strategies for endurance athletes at every level.',
    url: '#',
  },
  {
    title: 'The Anti-Diet Approach to Healthy Eating',
    outlet: 'Shape',
    category: 'Nutrition',
    description: 'Why ditching diet culture might be the healthiest choice you make.',
    url: '#',
  },
  {
    title: 'Supplements That Are Actually Worth Taking',
    outlet: 'SELF',
    category: 'Supplements',
    description: 'Cutting through the noise to identify supplements with real evidence behind them.',
    url: '#',
  },
];
---

<Layout title="Writing — Edwina Clark">
  <Nav />

  <section class="pt-32 pb-12 md:pt-44 md:pb-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-sm uppercase tracking-widest text-sage mb-2">Portfolio</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Writing</h1>
      <p class="text-lg text-charcoal-light max-w-2xl leading-relaxed">
        Bylined articles and expert content across nutrition, gut health, sports nutrition, fertility, and wellness — published in Shape, SELF, Well+Good, Yahoo Life, Women's Health, and more.
      </p>
    </div>
  </section>

  <!-- Filter tabs -->
  <section class="border-b border-warm-gray-dark sticky top-[65px] bg-cream/90 backdrop-blur-sm z-40">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex gap-6 overflow-x-auto py-4 -mb-px">
        {categories.map((cat, i) => (
          <button
            data-filter={cat.toLowerCase().replace(' ', '-')}
            class:list={[
              'text-sm tracking-wide uppercase whitespace-nowrap pb-2 border-b-2 transition-colors filter-btn',
              i === 0 ? 'border-sage text-sage' : 'border-transparent text-charcoal-light hover:text-sage'
            ]}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Articles grid -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="articles-grid">
        {articles.map(article => (
          <a href={article.url} class="group article-card block" data-category={article.category.toLowerCase().replace(' ', '-')}>
            <div class="aspect-[4/3] bg-peach/50 mb-4 rounded-sm overflow-hidden">
              <div class="w-full h-full flex items-center justify-center text-charcoal-light/30">
                <p class="text-sm">Article image</p>
              </div>
            </div>
            <span class="text-xs uppercase tracking-widest text-sage">{article.outlet} &middot; {article.category}</span>
            <h2 class="font-display text-xl font-semibold mt-2 mb-2 group-hover:text-sage transition-colors">{article.title}</h2>
            <p class="text-sm text-charcoal-light leading-relaxed">{article.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Writing CTA -->
  <section class="py-20 bg-sage-lighter">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-semibold mb-4">Looking for a health & nutrition writer?</h2>
      <p class="text-charcoal-light leading-relaxed mb-8">
        I write evidence-based health and nutrition content for publications, brands, and digital health companies. Let's talk about your next project.
      </p>
      <a href="/contact" class="inline-block bg-sage text-white px-8 py-4 text-sm font-medium uppercase tracking-wide hover:bg-sage-dark transition-colors">
        Hire Me to Write
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.article-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      buttons.forEach(b => {
        b.classList.remove('border-sage', 'text-sage');
        b.classList.add('border-transparent', 'text-charcoal-light');
      });
      btn.classList.add('border-sage', 'text-sage');
      btn.classList.remove('border-transparent', 'text-charcoal-light');

      cards.forEach(card => {
        const cat = card.getAttribute('data-category');
        if (filter === 'all' || cat === filter) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
