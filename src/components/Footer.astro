---
const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-white/70 py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-12">
      <div>
        <p class="font-display text-xl text-white mb-3">Edwina Clark</p>
        <p class="text-sm leading-relaxed">
          MS, RD, CSSD<br />
          Fractional CMO. Health writer. Media expert.<br />
          Science-driven wellness.
        </p>
      </div>
      <div>
        <p class="text-sm font-medium text-white uppercase tracking-wide mb-3">Navigate</p>
        <div class="flex flex-col gap-2">
          <a href="/services" class="text-sm hover:text-sage-light transition-colors">Services</a>
          <a href="/writing-media" class="text-sm hover:text-sage-light transition-colors">Writing & Media</a>
          <a href="/about" class="text-sm hover:text-sage-light transition-colors">About</a>
          <a href="/contact" class="text-sm hover:text-sage-light transition-colors">Contact</a>
        </div>
      </div>
      <div>
        <p class="text-sm font-medium text-white uppercase tracking-wide mb-3">Connect</p>
        <div class="flex flex-col gap-2">
          <a href="https://www.linkedin.com/in/edwinaclark/" target="_blank" rel="noopener" class="text-sm hover:text-sage-light transition-colors">LinkedIn</a>
          <a href="mailto:hello@edwinaclark.com" class="text-sm hover:text-sage-light transition-colors">hello@edwinaclark.com</a>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 mt-12 pt-8 text-center text-xs text-white/40">
      &copy; {year} Edwina Clark. All rights reserved.
    </div>
  </div>
</footer>
