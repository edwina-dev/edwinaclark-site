---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/services', label: 'Services' },
  { href: '/writing-media', label: 'Writing & Media' },
  { href: '/about', label: 'About' },
];
---

<nav class="fixed top-0 w-full bg-white/90 backdrop-blur-sm z-50 border-b border-sage-lighter">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="block">
      <img src="/images/logo.png" alt="Edwina Clark — Science-Driven Wellness" class="h-11 w-auto" />
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-toggle" class="md:hidden p-2" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm tracking-wider uppercase transition-colors',
            currentPath === link.href ? 'text-sage font-medium' : 'text-charcoal-light hover:text-sage'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="bg-sage text-white text-sm tracking-wider uppercase px-6 py-2.5 rounded-full hover:bg-sage-dark transition-colors">
        Get in Touch
      </a>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-sage-lighter">
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm tracking-wider uppercase transition-colors',
            currentPath === link.href ? 'text-sage font-medium' : 'text-charcoal-light hover:text-sage'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="bg-sage text-white text-sm tracking-wider uppercase px-6 py-2.5 rounded-full hover:bg-sage-dark transition-colors text-center">
        Get in Touch
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
